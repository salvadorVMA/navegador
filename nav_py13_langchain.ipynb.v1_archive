    "### query v2: creación de resúmenes temáticos"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "408d93e6",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "array([-0.01175261, -0.02690859,  0.01918369, ...,  0.00272391,\n",
       "       -0.02097107, -0.0183757 ], shape=(1536,), dtype=float32)"
      ]
     },
     "execution_count": 8,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "# query de la base de embeddings\n",
    "# query_emb es el embedding de la pregunta\n",
    "\n",
    "user_query= '¿qué significa ser mexicano para los mexicanos?'\n",
    "# turn it into a vector\n",
    "query_emb = embedding_fun_openai([user_query])[0]\n",
    "query_emb"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "4d5ec06c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[['CULTURA_POLITICA|¿Qué tan orgulloso se siente de ser mexicano?', 'IDENTIDAD_Y_VALORES|¿Qué tan orgulloso se siente de ser mexicano?', 'GLOBALIZACION|¿Qué tan orgulloso está de ser mexicano?', 'FEDERALISMO|¿Qué tan orgulloso se siente usted de ser mexicano?', 'INDIGENAS|¿Cuál cree que es la mayor ventaja de ser indígena en México?']]\n",
      "[[{'type': 'question', 'qid': 'p5|CUL'}, {'type': 'question', 'qid': 'p6|IDE'}, {'qid': 'p15|GLO', 'type': 'question'}, {'qid': 'p19_3|FED', 'type': 'question'}, {'qid': 'p13a_1|IND', 'type': 'question'}]]\n"
     ]
    }
   ],
   "source": [
    "# ejemplo: query entre las preguntas\n",
    "\n",
    "result_q = db_f1.query(\n",
    "    query_embeddings = [query_emb],\n",
    "    n_results        = 5,\n",
    "    where            = {\"type\": \"question\"}\n",
    ")\n",
    "\n",
    "print(result_q[\"documents\"])   # the matched question strings\n",
    "print(result_q[\"metadatas\"])   # metadata for each hit (includes qid & type)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "4d3a8b9e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Querying for type: question\n",
      "Querying for type: summary\n",
      "Querying for type: implications\n"
     ]
    }
   ],
   "source": [
    "# tmp_dist_df contiene las distancias para los tres tipos/ facets, normalizadas entre 0 y 1\n",
    "\n",
    "# OJO: esto obviamente asume que los tres tipos de información tienen la misma importancia, lo cual no es inicialmente cierto.\n",
    "# Pero la mezcla de las tres calificaciones devuelve una variedad más amplia de resultados.  \n",
    "\n",
    "type_lst = [ \"question\", \"summary\", \"implications\"]\n",
    "\n",
    "tmp_dist_dict = {}\n",
    "for type in type_lst:\n",
    "    print(f\"Querying for type: {type}\")\n",
    "    tmp_res_q = db_f1.query(\n",
    "        query_embeddings = [query_emb],\n",
    "        n_results        = 100,  # devuelvo 100 resultados para cada tipo con distancias menores\n",
    "        where            = {\"type\": type}\n",
    "    )\n",
    "    [tmp_res_ids] = tmp_res_q['ids']\n",
    "    [tmp_res_distances] = tmp_res_q['distances']\n",
    "\n",
    "    tmp_dist_dict[type]= dict(zip(tmp_res_ids, tmp_res_distances))\n",
    "\n",
    "# remove the suffixes from the keys\n",
    "tmp_dist_dict = { outer_key: { k.split('__')[0]: v for k, v in inner_dict.items() }\n",
    "    for outer_key, inner_dict in tmp_dist_dict.items() }\n",
    "\n",
    "# Create a DataFrame where keys in every subdict are the index and keys in tmp_dist_dict are columns\n",
    "tmp_dist_df = pd.DataFrame.from_dict(tmp_dist_dict)\n",
    "\n",
    "# Normalize each column so that max = 1 and min = 0\n",
    "tmp_dist_df = (tmp_dist_df - tmp_dist_df.min()) / (tmp_dist_df.max() - tmp_dist_df.min())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "3f573fe7",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "\"QUESTION_1|p1_1a_1|IDE: Con la palabra maíz, yo asocio comida, mercado, animales. Dígame por favor, tres palabras que asocies con la palabra MÉXICO. 1° MENCIÓN\\nSUMMARY_1|p1_1a_1|IDE: The table presents various associations that people have with the word 'México', showcasing a wide range of responses. The most prominent association is 'Orgullo', which reflects a strong sense of national pride at 25.25%, followed by 'Costumbres y tradiciones' at 13.50%, and 'Historia y cultura' at 7.58%. Notably, the 'No sabe/ No contesta' response is at 9.75%, indicating a significant portion of respondents either do not have an association or are unwilling to share. This highlights potential gaps in connection or sentiment towards the national identity.\\nQUESTION_2|p2_1a_1|IDE: Y ahora, voy a pedir que me diga, por favor, tres palabras que asocie con la palabra MEXICANO. 1° MENCIÓN\\nSUMMARY_2|p2_1a_1|IDE: The table presents various words and phrases associated with the identity of 'Mexicano', indicating a range of perceptions from positive attributes like 'Trabajador' (hardworking) at 13.67% to negative stereotypes like 'Corrupto' (corrupt) at 3.58%. The most mentioned words reflect positive values related to work ethic, community, and pride, while a notable portion (12.83%) of respondents selected 'No sabe/ No contesta', highlighting uncertainty or lack of clarity in their perceptions.\\nQUESTION_3|p4|IDE: ¿Con cuál de estas dos frases está usted más de acuerdo?\\nSUMMARY_3|p4|IDE: The table presents opinions on national identity and values among Mexicans. A majority (55.25%) agree that a great nation can be built despite having distinct cultures and values, while 38.42% believe similarity in culture and values is necessary. A small portion (4.00% combined) selected spontaneous options indicating no agreement or were undecided, suggesting some uncertainty in public sentiment about national cohesion.\\nQUESTION_4|p5_1|IDE: ¿Cuál de las siguientes emociones refleja mejor lo que siente sobre México?  1° MENCIÓN\\nSUMMARY_4|p5_1|IDE: The table presents the emotional sentiments of individuals regarding Mexico, with the predominant feeling being 'Pride' at 38.33%. Other emotions such as 'Concern' (17.00%) and 'Anger' (11.25%) also hold significance, while 'Love' and 'Solidarity' are notably low at 0.83% and 0.08%, respectively. The 'No sabe/ No contesta' category accounts for 6.00%, indicating that a notable proportion of respondents were uncertain or unwilling to express their feelings, which suggests a potential area for further exploration in understanding public sentiment.\\nQUESTION_5|p6|IDE: ¿Qué tan orgulloso se siente de ser mexicano?\\nSUMMARY_5|p6|IDE: The table presents data on how proud individuals feel about being Mexican, with 63.42% expressing a strong sense of pride ('Mucho'), while only 25.42% feel some pride ('Algo'). A small percentage feel little pride ('Poco') or no pride at all ('Nada'), and 0.50% do not identify as Mexican. Notably, 0.25% of respondents did not provide an answer, which is below the 2.0% threshold, indicating that most respondents felt comfortable expressing their views.\\nQUESTION_6|p7|IDE: Usted se siente…\\nSUMMARY_6|p7|IDE: The table presents the perceptions of identity among respondents in relation to their Mexican and Yucateco identities. A significant 42.00% identify as 'Sólo mexicano', while 15.00% feel 'Más (yucateco) que mexicano'. The combined percentage of those who identify exclusively or predominantly as Yucateco (15.00% + 4.42%) is notable, indicating a distinct local identity. Additionally, the 'No sabe/ No contesta' category stands at 1.50%, which is below the 2.0% threshold, suggesting that most respondents have a clear view of their identity.\\nQUESTION_7|p46_4|IDE: Y Ahora dígame; en su opinión ¿qué tanto los mexicanos mienten para obtener un beneficio?\\nSUMMARY_7|p46_4|IDE: The table indicates perceptions of dishonesty among Mexicans regarding obtaining benefits, with 43.75% believing that many lie, 36.33% saying that some do, and only 12.08% indicating that few lie. A small percentage (5.17%) believes that no one lies and 2.67% of respondents did not answer or did not know, which is significant as it reflects uncertainty or discomfort with the question.\\nQUESTION_8|p78|IDE: ¿Usted cree que el gobierno se debe apoyar en las ideas de la Revolución Mexicana o debe cambiar de ideas?\\nSUMMARY_8|p78|IDE: The table presents the perspectives of individuals regarding whether the government should rely on the ideas of the Mexican Revolution or change its ideologies. 36% believe it should support the Revolution's ideas, while 31.5% think it should change. Additionally, 24.08% feel that some ideas should change or continue, and 8.42% of respondents do not know or did not answer, indicating a notable uncertainty in public opinion.\\nQUESTION_9|p32|POB: En su opinión, ¿cree que en México hay mexicanos de primera y segunda o que todos son iguales?\\nSUMMARY_9|p32|POB: The table presents public opinion in Mexico regarding social equality, with 36.92% of respondents believing there are first and second class Mexicans, while 60.42% think everyone is equal. Notably, the 'No sabe/ No contesta' category accounts for 2.67%, signaling a significant portion of uncertainty or lack of opinion on this issue.\\nQUESTION_10|p5|CUL: ¿Qué tan orgulloso se siente de ser mexicano?\\nSUMMARY_10|p5|CUL: The table presents the pride levels of individuals identifying as Mexican, with 59.67% feeling a strong sense of pride ('Mucho'), 27.50% feeling little pride ('Poco'), and 10.17% not feeling any pride ('Nada'). A small percentage (1.83%) do not identify as Mexican, while 0.42% chose 'Otra' and another 0.42% did not provide an answer or were unsure. The significant percentage of 'No sabe/ No contesta' is below 2.0%, indicating a relatively high level of engagement with the question among respondents.\\nQUESTION_11|p13|IND: ¿Cuál cree que es la mayor ventaja de ser indígena en México?\\nSUMMARY_11|p13|IND: The table displays the perceived advantages of being Indigenous in Mexico, with 'sus tradiciones y costumbres' (traditions and customs) topping the list at 12.93%. Other notable mentions include culture (7.26%) and communication in another language (6.09%). However, a significant portion of respondents (33.03%) indicated they did not know or did not answer the question, highlighting potential uncertainty or lack of awareness surrounding Indigenous identities and their associated benefits.\\nQUESTION_12|p13a_1|IND: ¿Cuál cree que es la mayor ventaja de ser indígena en México?\\nSUMMARY_12|p13a_1|IND: The table presents data on perceived advantages of being Indigenous in Mexico. The majority of respondents (20.27%) believe that traditions are the greatest advantage. Other notable advantages include language (6.09%) and natural resources (3.92%). However, a significant portion, 33.03%, either does not know or did not answer, highlighting a potential uncertainty or lack of awareness about Indigenous identity benefits.\\nQUESTION_13|p14|IND: ¿Y cuál cree que es la mayor desventaja de ser indígena en México?\\nSUMMARY_13|p14|IND: The table presents various perceived disadvantages of being Indigenous in Mexico, with the most significant concern being discrimination at 43.62%. Other notable issues include poverty (7.34%) and marginalization (5.25%). The 'No sabe/No contesta' category accounts for 19.27%, indicating a substantial portion of respondents were unable or unwilling to provide an answer, which highlights potential uncertainty or lack of awareness regarding Indigenous issues.\\nQUESTION_14|p14a_1|IND: ¿Y cuál cree que es la mayor desventaja de ser indígena en México?\\nSUMMARY_14|p14a_1|IND: The table presents the perceived disadvantages of being indigenous in Mexico, highlighting that 45.12% of respondents identify discrimination as the biggest issue. Other notable concerns include marginalization and poverty at 20.27%. The 'No sabe/ No contesta' option accounts for 19.27%, indicating uncertainty or lack of knowledge among respondents, which suggests a significant portion of the population may not fully understand the challenges faced by indigenous people.\\nQUESTION_15|p33_4|IND: ¿Qué tanto considera que los siguientes grupos de personas hacen valer sus derechos en México? Mestizos\\nSUMMARY_15|p33_4|IND: The table presents the perceived effectiveness of mestizos in advocating for their rights in Mexico, with 11.01% indicating 'always', 39.12% 'most of the time', 32.28% 'almost never', and 12.84% 'never'. Notably, 4.75% of respondents chose 'no sabe/no contesta', suggesting a significant portion of the population may be uncertain about the topic.\\nQUESTION_16|p34_4|IND: ¿Usted considera que ser indígena en México es un obstáculo o no para entrar a un restaurante?\\nSUMMARY_16|p34_4|IND: The table indicates that a majority of respondents (58.05%) believe being indigenous in Mexico poses an obstacle when entering a restaurant. Only 25.69% disagreed, while 14.43% thought it was partially a barrier. Notably, the 'No sabe/ No contesta' category at 1.83% does not exceed 2.0%, indicating a low level of uncertainty among respondents regarding this issue.\\nQUESTION_17|p6_2a_1|GLO:  6.2. ¿Y cuál es el motivo por el que se iría a vivir fuera de  México?\\nSUMMARY_17|p6_2a_1|GLO: The table outlines the reasons individuals would consider moving from Mexico, with the majority citing 'Calidad de vida/Mejores oportunidades' (6.75%) and 'Trabajo' (6.58%) as primary motivations. Lesser motivations include 'Inseguridad en el país' (5.17%) and 'Conocer/cultura' (5.75%). Notably, the 'Mala situación política' and personal reasons have minimal impact, both below 1%. The 'No le gusta México' option is also quite low at 0.42%. There are no rows indicating 'no answer/does not know' exceeding 2.0%; this suggests strong sentiments or clarity among respondents.\\nQUESTION_18|p15|GLO: ¿Qué tan orgulloso está de ser mexicano?\\nSUMMARY_18|p15|GLO: The table presents the levels of pride among Mexicans regarding their nationality, showing that 89.25% of respondents are either 'very proud' (55.67%) or 'proud' (33.58%). Only a small percentage express minimal or no pride, with 1.33% being 'not at all proud' and 0.08% selecting 'other.' Notably, the 'no answer/no response' category is at 0.42%, which does not exceed 2.0%, indicating most respondents had a clear stance.\\nQUESTION_19|p16_1|GLO: ¿Qué tan orgulloso está usted de México en cada uno de los siguientes ámbitos? El funcionamiento de la democracia\\nSUMMARY_19|p16_1|GLO: The table presents the levels of pride Mexicans feel towards their country's democracy. A majority (35.25%) feel 'Poco orgulloso' (a little proud), followed by those who are 'Algo orgulloso' (29.50%). Only 7.17% report being 'Muy orgulloso' (very proud), while a significant 24.75% express that they are 'Nada orgulloso' (not proud at all). Additionally, the 'No sabe/No contesta' (does not know/no answer) responses, at 1.67%, do not exceed 2.0%, indicating a relatively low level of indecision among respondents regarding their feelings towards democracy in Mexico.\\nQUESTION_20|p16_2|GLO: ¿Qué tan orgulloso está usted de México en cada uno de los siguientes ámbitos? Su influencia política en el mundo\\nSUMMARY_20|p16_2|GLO: The table presents the pride of Mexicans regarding their country's political influence in the world. 6.92% reported being 'very proud', 27.67% 'somewhat proud', 36.08% 'a little proud', and 24.50% 'not proud at all'. Notably, 3.33% either do not know or did not answer, which suggests a significant portion of the population may feel uncertain about their country's global political standing.\\nQUESTION_21|p16_3|GLO: ¿Qué tan orgulloso está usted de México en cada uno de los siguientes ámbitos? Sus logros económicos\\nSUMMARY_21|p16_3|GLO: The table presents the level of pride Mexicans feel regarding their country's economic achievements. A majority, 35.92%, reported feeling 'poco orgulloso' (a little proud), while 27.33% indicated they were 'algo orgulloso' (somewhat proud). Only 10.50% expressed 'muy orgulloso' (very proud), and 23.42% stated 'nada orgulloso' (not proud at all). Notably, the 'No sabe/ No contesta' category accounts for 1.92%, which exceeds 2.0%, highlighting a significant uncertainty or disengagement among some respondents.\\nQUESTION_22|p18_5|GLO: ¿Qué tan importante es cada una de las siguientes acciones para ser nacionalista? Preferir la música y películas mexicanas a la extranjeras\\nSUMMARY_22|p18_5|GLO: The table presents data on the importance of preferring Mexican music and films over foreign options as a measure of nationalism, with varying percentages reflecting different levels of agreement. A notable percentage of respondents (3.75%) chose 'No sabe/ No contesta', indicating uncertainty or lack of opinion on this matter, which could reflect ambivalence about national identity or a lack of engagement with cultural preferences.\\nQUESTION_23|p19_1|MIG: Si usted decidiera vivir en otro país, ¿cuáles serían las tres cosas que extrañaría MÁS de México, en orden de importancia? 1° MENCIÓN\\nSUMMARY_23|p19_1|MIG: The table presents the top three things that individuals would miss the most about Mexico if they decided to live in another country. The most significant factor is 'Familia' (family), with 68.47%, followed by 'Comida' (food) at 8.76%, and 'Amigos' (friends) at 6.26%. Other aspects such as the cultural identity ('Mexicanos'), music, and climate received much lower percentages. Notably, the 'No sabe/No contesta' (does not know/no answer) category is at 2.42%, which exceeds 2.0% and may indicate uncertainty or reluctance to express preferences about their connections to Mexico.\\nQUESTION_24|p28|MIG: ¿Cuál considera que es la principal causa por la cual los mexicanos deciden cruzar a Estados Unidos?\\nSUMMARY_24|p28|MIG: The table presents the main reasons why Mexicans decide to migrate to the United States. The primary cause identified is economic reasons/work, accounting for 89.41% of responses. Other notable causes include family reunification (4.34%) and insecurity in Mexico (2.92%). Responses indicating 'no answer/no comment' are at 1.58%, which is below the 2.0% threshold, suggesting that a majority of respondents are clear about their motivations.\\nQUESTION_25|p29a|MIG: En su opinión, ¿cuál es el principal beneficio que obtiene México por la migración de mexicanos a Estados Unidos?\\nSUMMARY_25|p29a|MIG: The table shows the perceived benefits Mexico gains from the migration of Mexicans to the United States, with the most notable benefit being remittances at 36.86%. Other benefits noted include improvements in family living standards (4.59%) and a general economic improvement (6.59%). A significant 31.61% of respondents believe there are no benefits, and 15.35% did not know or did not answer, indicating uncertainty or lack of awareness about the topic.\\nQUESTION_26|p37|MIG: Para usted, ¿cuál es el principal motivo por el que los mexicanos que viven en Estados Unidos no regresan a México?\\nSUMMARY_26|p37|MIG: The table presents the reasons why Mexicans living in the United States do not return to Mexico. The majority (52.63%) cite the level of life as the main reason, followed by the difficulty of adapting again (19.68%) and the challenges of crossing back into the U.S. (25.60%). A small percentage (0.75%) indicated other reasons, while 1.33% did not answer or did not know. Although the 'no answer/no know' response does not exceed 2.0%, it still reflects a minor uncertainty among respondents.\\nQUESTION_27|p39|MIG: ¿Cuál cree usted que es el principal problema de los mexicanos que regresan al país después de vivir en el extranjero?\\nSUMMARY_27|p39|MIG: The table presents the main issues faced by Mexicans returning to the country after living abroad. The predominant concern is the lack of job opportunities, affecting 59.63% of respondents. Adaptation difficulties follow at 26.19%, while health deterioration, lack of problems, and other concerns constitute smaller percentages. Notably, 2.42% of respondents chose 'no answer/no know', indicating a significant portion who may be uncertain or unwilling to express their views.\\nQUESTION_28|p43_3|MIG: Dígame por favor ¿Qué tan de acuerdo o en desacuerdo está con las siguientes afirmaciones sobre los extranjeros que viven en México?  Generan inseguridad\\nSUMMARY_28|p43_3|MIG: The table presents opinions about foreigners living in Mexico regarding the perception of insecurity. 12.84% of respondents agree, while 20.68% partially agree. 25.77% are neutral, and 14.43% partially disagree, with 22.69% disagreeing completely. Notably, 3.59% of respondents did not provide an answer or expressed uncertainty, indicating a significant portion of the population may be unsure about their view on this issue.\\nQUESTION_29|p43_4|MIG: Dígame por favor ¿Qué tan de acuerdo o en desacuerdo está con las siguientes afirmaciones sobre los extranjeros que viven en México?  Traen ideas innovadoras\\nSUMMARY_29|p43_4|MIG: The table presents survey responses regarding perceptions of foreigners living in Mexico and their contribution of innovative ideas. 26.36% strongly agree, and 27.52% somewhat agree with the statement, while 23.10% are neutral. A smaller percentage (8.59% partially disagree and 8.34% fully disagree) shows a level of skepticism. Notably, 6.09% of respondents did not provide an answer or indicated they did not know, which exceeds 2.0%, highlighting uncertainty or lack of opinion among a segment of the population.\\nQUESTION_30|p48|MIG: Usted cree que los extranjeros que viven en México deben tener…\\nSUMMARY_30|p48|MIG: The table presents public opinion on the rights of foreigners living in Mexico. A significant majority, 79.65%, believe that they should have the same rights as Mexicans, while only 12.43% think they should have fewer rights. A mere 3.25% believe foreigners should have more rights, and 1.67% offer other opinions. Notably, 3.00% of respondents chose 'No sabe/No contesta', indicating uncertainty or lack of opinion, which suggests a need for further public education on the topic.\\nQUESTION_31|p50_5|MIG: En comparación con los mexicanos, en general, para un extranjero que vive en México ¿es más fácil, igual o más difícil estudiar?\\nSUMMARY_31|p50_5|MIG: The table presents the perceptions of foreigners living in Mexico regarding the ease of studying compared to Mexicans. Approximately 34.61% find it easier to study, while 43.95% believe it is about the same, and 17.68% feel it is more difficult. Notably, 3.75% of respondents did not know or chose not to answer, indicating a significant portion of uncertainty or ambivalence about the comparative ease of studying.\\nQUESTION_32|p50_6|MIG: En comparación con los mexicanos, en general, para un extranjero que vive en México ¿es más fácil, igual o más difícil realizar trámites?\\nSUMMARY_32|p50_6|MIG: La tabla muestra las percepciones de los extranjeros que viven en México sobre la facilidad de realizar trámites en comparación con los mexicanos. Un 36.86% considera que es igual de fácil, mientras que el 29.11% opina que es más fácil y el 28.61% que es más difícil. Un 5.42% de los encuestados no sabe o no contesta, lo que indica que existe un número significativo de personas que pueden no estar seguras de su experiencia o del proceso migratorio en general.\\nQUESTION_33|p50_7|MIG: En comparación con los mexicanos, en general, para un extranjero que vive en México ¿es más fácil, igual o más difícil encontrar pareja?\\nSUMMARY_33|p50_7|MIG: The table shows that 41.53% of respondents believe it is easier for a foreigner living in Mexico to find a partner compared to Mexicans, while 42.12% think it is the same, and only 11.01% think it is more difficult. Notably, 5.34% of respondents did not know or did not answer the question, which is significant as it indicates a portion of the population is unsure about this subject.\\nQUESTION_34|p51|MIG: En general, ¿qué tanto considera que los mexicanos discriminan a los extranjeros que viven en el país?\\nSUMMARY_34|p51|MIG: The table presents the perceived discrimination of Mexicans towards foreigners living in Mexico. A significant percentage, 37.28%, believes that Mexicans discriminate 'algo' (somewhat), while 7.59% think they discriminate 'mucho' (a lot). In total, 66.89% perceive some level of discrimination (either 'mucho' or 'algo'). Notably, 4.34% of respondents chose 'no sabe/ no contesta' (don't know/no answer), indicating a portion of the population may be uncertain about this social issue, which could reflect a lack of awareness or sensitivity towards discrimination against foreigners.\\nQUESTION_35|p53|MIG: En su opinión, ¿qué extranjeros que viven en el país son más discriminados por los mexicanos?\\nSUMMARY_35|p53|MIG: The table presents perceptions of discrimination against various groups of foreigners living in Mexico. The highest perceived discrimination is against Africans (8.76%) and Guatemalans (7.76%), while lower percentages are noted for Americans (2.42%) and Spaniards (0.17%). Notably, 46.96% of respondents either did not know or chose not to answer the question, indicating a significant level of uncertainty or disengagement concerning the topic.\\nQUESTION_36|p65|MIG: Desde las elecciones de 2006 los mexicanos que viven en el extranjero pueden votar desde la distancia para elegir al Presidente de la República. ¿Usted considera que esto fortalece la democracia mexicana o es un gasto innecesario de recursos públicos?\\nSUMMARY_36|p65|MIG: The table presents data on Mexican citizens living abroad and their opinions regarding voting from overseas since the 2006 elections. 44.62% believe it is an unnecessary public expense, while 33.44% feel it strengthens democracy. 10.01% chose 'none,' 6.76% indicated 'both,' and 5.17% did not know or did not respond. The significant percentage of 'no answer/does not know' indicates ambivalence or lack of information among respondents.\\nQUESTION_37|p67_1|MIG: Y con respecto a los inmigrantes indocumentados que vienen a México ¿Usted considera que el gobierno mexicano debería o no debería permitir su entrada sin obstáculos?\\nSUMMARY_37|p67_1|MIG: The table presents opinions on whether the Mexican government should allow undocumented immigrants to enter the country without obstacles. 27.36% believe it should, 33.61% say it depends, and 36.36% oppose it. Notably, 2.67% of respondents did not provide an answer or did not know, indicating a minor level of uncertainty or ambivalence in public opinion.\\nQUESTION_38|p67_5|MIG: Y con respecto a los inmigrantes indocumentados que vienen a México ¿Usted considera que el gobierno mexicano debería o no debería construir un muro en la frontera sur?\\nSUMMARY_38|p67_5|MIG: The table presents public opinion regarding whether the Mexican government should construct a wall on the southern border to manage undocumented immigration. A total of 21.27% believe it should be built, 25.85% have a conditional opinion ('depends'), while the majority, at 48.96%, are against its construction. Additionally, 3.92% of respondents did not provide an answer or expressed uncertainty, which is significant as it suggests a notable level of ambivalence or lack of clear opinion on the subject.\\nQUESTION_39|p19_3|FED: ¿Qué tan orgulloso se siente usted de ser mexicano?\\nSUMMARY_39|p19_3|FED: The table displays the levels of pride among Mexicans regarding their nationality, with 63.58% expressing 'very proud' and 23.75% 'somewhat proud'. A minority, 11.67% combined (8.92% 'a little proud' and 2.75% 'not at all proud'), indicates lower levels of pride. Notably, the 'no answer/does not know' category is 1.00%, which does not exceed 2.0%, suggesting a relatively clear perspective among respondents.\\nQUESTION_40|p53|DEP: Aparte de la nacionalidad mexicana, ¿tiene otra(s) nacionalidad(es)?\\nSUMMARY_40|p53|DEP: The table presents responses regarding additional nationalities among individuals primarily identifying as Mexican. A significant 96.92% of respondents indicated that they do not hold any other nationality, while only 1.75% confirmed having another nationality. The 'No sabe/ No contesta' category accounted for 1.33%, which does not exceed the 2.0% threshold.\""
      ]
     },
     "execution_count": 14,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "# tmp_res_st contiene las 40 preguntas más cercanas y la descripción de sus resultados.\n",
    "\n",
    "top_vals = 40\n",
    "\n",
    "tmp_dist_df['mean'] = tmp_dist_df.mean(axis=1)\n",
    "tmp_dist_df.sort_values(by='mean', ascending=True, inplace=True)\n",
    "\n",
    "top_ids = tmp_dist_df.head(top_vals).index.tolist()\n",
    "\n",
    "tmp_list = []\n",
    "\n",
    "for type in type_lst:\n",
    "    for id in top_ids:\n",
    "        tmp_list.append(id + f'__{type}')\n",
    "\n",
    "\n",
    "# Retrieve documents using the list of ids\n",
    "result_by_ids = db_f1.get(ids=tmp_list)\n",
    "\n",
    "tmp_pre_res_dict = dict(zip(result_by_ids['ids'], result_by_ids['documents']))\n",
    "\n",
    "tmp_preproc_dic = {k: v for k, v in tmp_pre_res_dict.items() if k.split('__')[1] in ['question', 'summary'] }\n",
    "\n",
    "# # instead of your current list-comp do this:\n",
    "tmp_combined_strings = []\n",
    "\n",
    " # Calculate the group index based on the position\n",
    "\n",
    "for i, (k, v) in enumerate(tmp_preproc_dic.items(), start=1):\n",
    "    facet = k.split(\"__\", 1)[1].upper()\n",
    "    p_id = k#.split(\"__\")[0].split(\"|\")[0]\n",
    "\n",
    "    grouped_index = (i + 1) // 2 \n",
    "    # only split once, and if there is no \"|\" take the entire v\n",
    "    q_id = v.split(\"|\")[0]\n",
    "    parts = v.split(\"|\", 1)\n",
    "    text = parts[1] if len(parts) > 1 else parts[0]\n",
    "\n",
    "    p_id = p_id.split(\"__\")[0]\n",
    "\n",
    "    tmp_combined_strings.append(f\"{facet}_{grouped_index}|{p_id}: {text}\")\n",
    "\n",
    "tmp_res_st = '\\n'.join(tmp_combined_strings)\n",
    "tmp_res_st"
   ]
  },
  {
   "cell_type": "code",
