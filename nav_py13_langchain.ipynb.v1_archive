    "import os\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 1) your existing dicts of content\n",
    "texts = {\n",
    "    \"Introduction\": \"This is my _intro_ text.\",\n",
    "    \"Results\": \"Here are the results of the analysis.\"\n",
    "    # …etc…\n",
    "}\n",
    "\n",
    "# 2) a matching dict of plot-builders\n",
    "#    each value is a zero-arg function that draws on plt\n",
    "plots = {\n",
    "    \"Results\": lambda: plt.plot([1,2,3],[4,5,6], label=\"demo\"),\n",
    "    # … you can stash more e.g. \"Analysis\": make_analysis_plot …\n",
    "}\n",
    "\n",
    "# prepare output dirs\n",
    "os.makedirs(\"images\", exist_ok=True)\n",
    "\n",
    "md_lines = []\n",
    "\n",
    "for section, text in texts.items():\n",
    "    # section header\n",
    "    md_lines.append(f\"# {section}\")\n",
    "    # paragraph text\n",
    "    md_lines.append(text)\n",
    "    \n",
    "    # if there's a plot for this section\n",
    "    if section in plots:\n",
    "        img_file = f\"images/{section.replace(' ','_').lower()}.png\"\n",
    "        \n",
    "        # draw & save\n",
    "        plots[section]()          # your lambda/callback draws on plt\n",
    "        plt.tight_layout()\n",
    "        plt.savefig(img_file, dpi=150)\n",
    "        plt.close()\n",
    "        \n",
    "        # embed in markdown\n",
    "        md_lines.append(f\"![{section}]({img_file})\")\n",
    "\n",
    "# write out the markdown file\n",
    "with open(\"report.md\", \"w\") as f:\n",
    "    f.write(\"\\n\\n\".join(md_lines))\n",
    "\n",
    "print(\"✅ report.md and images/ saved.\")"
   ]
  },
