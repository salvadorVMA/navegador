    "# carga de db_f1 en chroma\n",
    "\n",
    "DB_PERSIST_DIR = \"./db_f1\"\n",
    "\n",
    "client = chromadb.PersistentClient(\n",
    "    path=DB_PERSIST_DIR,\n",
