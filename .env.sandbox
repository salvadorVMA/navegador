# .env.sandbox - Test Environment Variables for Claude1 Sandbox
# DO NOT USE PRODUCTION API KEYS HERE
# This file is for isolated testing only

# =============================================================================
# API KEYS (Use test/low-quota keys only)
# =============================================================================
# OPENAI_API_KEY=sk-test-your-test-key-here
# ANTHROPIC_API_KEY=sk-ant-test-your-test-key-here

# =============================================================================
# LANGSMITH (Optional - for debugging)
# =============================================================================
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key
# LANGCHAIN_PROJECT=navegador-sandbox

# =============================================================================
# NAVEGADOR CONFIGURATION
# =============================================================================
NAVEGADOR_PROJECT_ROOT=/sandbox/navegador
NAVEGADOR_CACHE_DIR=/sandbox-data/cache
NAVEGADOR_LOG_DIR=/sandbox-data/logs
NAVEGADOR_CHROMADB_DIR=/sandbox-data/chromadb
NAVEGADOR_PROMPT_DATA_DIR=/sandbox-data/prompt_data

# =============================================================================
# TESTING FLAGS
# =============================================================================
NAVEGADOR_TESTING_MODE=true
NAVEGADOR_USE_CACHE=true
NAVEGADOR_LOG_LEVEL=DEBUG
NAVEGADOR_SAFE_MODE=true

# =============================================================================
# RESOURCE LIMITS
# =============================================================================
NAVEGADOR_MAX_WORKERS=2
NAVEGADOR_CACHE_SIZE=1000
NAVEGADOR_CACHE_TTL=3600
NAVEGADOR_REQUEST_TIMEOUT=30
NAVEGADOR_MAX_MEMORY_MB=2048

# =============================================================================
# FEATURE FLAGS
# =============================================================================
NAVEGADOR_ENABLE_META_PROMPTING=true
NAVEGADOR_ENABLE_REQUEST_MANAGER=true
NAVEGADOR_ENABLE_THREAD_POOL=true
NAVEGADOR_ENABLE_ERROR_HANDLER=true

# =============================================================================
# PERFORMANCE OPTIMIZATION
# =============================================================================
NAVEGADOR_ENABLE_CACHING=true
NAVEGADOR_CACHE_BACKEND=memory
NAVEGADOR_ENABLE_CHROMADB_CACHE=false

# =============================================================================
# MONITORING
# =============================================================================
NAVEGADOR_ENABLE_PERFORMANCE_TRACKING=true
NAVEGADOR_ENABLE_QUALITY_SCORING=true
NAVEGADOR_TRACK_TOKEN_USAGE=true

# =============================================================================
# NOTES
# =============================================================================
# 1. Copy this file and add real test API keys (with spending limits)
# 2. Never commit files with real API keys
# 3. Use separate keys for sandbox vs production
# 4. Monitor API usage to avoid unexpected costs
